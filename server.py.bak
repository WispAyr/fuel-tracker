    data["forecast"] = _generate_forecast(data.get("trends", []))
    return data



@app.get("/api/forecast")
async def forecast_endpoint(
    type: str = "city",
    name: str = "Ayr",
    fuel: str = "E10",
    days: int = 14,
):
    data = await _fetch("/prices/history", {
        "type": type, "name": name, "fuel": fuel, "days": 90,
