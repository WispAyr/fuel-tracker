"""Fuel Price Tracker for Ayr & Ayrshire — FastAPI backend with caching proxy."""

import argparse
import math
import hashlib
import sqlite3
import asyncio
import time
from datetime import datetime, timezone, timedelta
from pathlib import Path
from zoneinfo import ZoneInfo

import httpx
from fastapi.middleware.cors import CORSMiddleware
from fastapi import FastAPI, Request, HTTPException
from fastapi.responses import FileResponse, JSONResponse
from pydantic import BaseModel

app = FastAPI(title="Fuel Price Tracker — Ayr & Ayrshire")
app.add_middleware(CORSMiddleware, allow_origins=["*"], allow_methods=["GET"], allow_headers=["*"])

BASE_URL = "https://fuelcosts.co.uk/api"
DEFAULT_LAT = 55.458
DEFAULT_LON = -4.629
DEFAULT_RADIUS = 20
CACHE_TTL = 300  # 5 minutes

UK_TZ = ZoneInfo("Europe/London")

_cache: dict[str, tuple[float, any]] = {}

DB_PATH = Path(__file__).parent / "sightings.db"

DAY_NAMES = ["monday", "tuesday", "wednesday", "thursday", "friday", "saturday", "sunday"]


# ── SQLite Sightings DB ────────────────────────────────

def _init_db():
    conn = sqlite3.connect(DB_PATH)
    conn.execute("""
        CREATE TABLE IF NOT EXISTS sightings (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            station_id TEXT NOT NULL,
            timestamp TEXT NOT NULL,
            ip_hash TEXT NOT NULL,
            has_fuel INTEGER NOT NULL,
            queue_length TEXT NOT NULL,
            note TEXT
        )
    """)
    conn.execute("CREATE INDEX IF NOT EXISTS idx_station_ts ON sightings(station_id, timestamp)")
    conn.execute("""
        CREATE TABLE IF NOT EXISTS congestion_history (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            station_id TEXT NOT NULL,
            timestamp TEXT NOT NULL,
            score REAL NOT NULL,
            status TEXT NOT NULL,
            nearby_incidents INTEGER DEFAULT 0
        )
    """)
    conn.execute("CREATE INDEX IF NOT EXISTS idx_congestion_station_ts ON congestion_history(station_id, timestamp)")
    conn.commit()
    conn.close()


_init_db()


# ── Cache helpers ──────────────────────────────────────

def _cache_key(url: str, params: dict | None = None) -> str:
    parts = [url]
    if params:
        parts.extend(f"{k}={v}" for k, v in sorted(params.items()))
    return "|".join(parts)


async def _fetch(path: str, params: dict | None = None) -> dict:
    url = f"{BASE_URL}{path}"
    key = _cache_key(url, params)
    now = time.time()
    if key in _cache:
        ts, data = _cache[key]
        if now - ts < CACHE_TTL:
            return data
    async with httpx.AsyncClient(timeout=15) as client:
        resp = await client.get(url, params=params)
        resp.raise_for_status()
        data = resp.json()
        _cache[key] = (now, data)
        return data


# ── Opening Hours ──────────────────────────────────────

def _parse_time(ts: str) -> tuple[int, int]:
    """Parse HH:MM:SS or HH:MM -> (hour, minute)."""
    parts = ts.split(":")
    return int(parts[0]), int(parts[1])


def _format_time_ampm(hour: int, minute: int) -> str:
    """Format 24h hour/minute to 12h AM/PM."""
    suffix = "AM" if hour < 12 else "PM"
    h = hour % 12 or 12
    if minute == 0:
        return f"{h}:00 {suffix}"
    return f"{h}:{minute:02d} {suffix}"


def _compute_open_status(station: dict) -> dict:
    """Compute is_open_now, open_status, and next_change for a station."""
    if station.get("is_permanently_closed"):
        return {"is_open_now": False, "open_status": "Permanently Closed", "next_change": None}
    if station.get("is_temporarily_closed"):
        return {"is_open_now": False, "open_status": "Temporarily Closed", "next_change": None}

    opening_times = station.get("opening_times") or {}
    usual_days = opening_times.get("usual_days") or {}

    if not usual_days:
        return {"is_open_now": None, "open_status": "Hours unknown", "next_change": None}

    now_uk = datetime.now(UK_TZ)
    today_name = DAY_NAMES[now_uk.weekday()]
    today_info = usual_days.get(today_name) or {}

    if today_info.get("is_24_hours"):
        all_24 = all((v or {}).get("is_24_hours") for v in usual_days.values())
        if all_24:
            return {"is_open_now": True, "open_status": "Open 24hrs", "next_change": None}
        return {"is_open_now": True, "open_status": "Open 24hrs today", "next_change": None}

    if not today_info.get("open") or not today_info.get("close"):
        for i in range(1, 8):
            day_idx = (now_uk.weekday() + i) % 7
            day_name = DAY_NAMES[day_idx]
            day_info = usual_days.get(day_name) or {}
            if day_info.get("is_24_hours") or (day_info.get("open") and day_info.get("close")):
                if day_info.get("is_24_hours"):
                    open_str = "midnight"
                else:
                    oh, om = _parse_time(day_info["open"])
                    open_str = _format_time_ampm(oh, om)
                day_label = "tomorrow" if i == 1 else day_name.capitalize()
                return {
                    "is_open_now": False,
                    "open_status": f"Closed \u2014 Opens {open_str} {day_label}",
                    "next_change": {"type": "opens", "day": day_name, "time": open_str},
                }
        return {"is_open_now": False, "open_status": "Closed today", "next_change": None}

    open_h, open_m = _parse_time(today_info["open"])
    close_h, close_m = _parse_time(today_info["close"])

    now_minutes = now_uk.hour * 60 + now_uk.minute
    open_minutes = open_h * 60 + open_m
    close_minutes = close_h * 60 + close_m

    if open_minutes <= now_minutes < close_minutes:
        mins_to_close = close_minutes - now_minutes
        close_str = _format_time_ampm(close_h, close_m)
        status = f"Open until {close_str}"
        return {
            "is_open_now": True,
            "open_status": status,
            "next_change": {"type": "closes", "minutes": mins_to_close, "time": close_str},
        }
    elif now_minutes < open_minutes:
        open_str = _format_time_ampm(open_h, open_m)
        return {
            "is_open_now": False,
            "open_status": f"Closed \u2014 Opens {open_str}",
            "next_change": {"type": "opens", "time": open_str, "minutes": open_minutes - now_minutes},
        }
    else:
        for i in range(1, 8):
            day_idx = (now_uk.weekday() + i) % 7
            day_name = DAY_NAMES[day_idx]
            day_info = usual_days.get(day_name) or {}
            if day_info.get("is_24_hours") or (day_info.get("open") and day_info.get("close")):
                if day_info.get("is_24_hours"):
                    open_str = "midnight"
                else:
                    oh, om = _parse_time(day_info["open"])
                    open_str = _format_time_ampm(oh, om)
                day_label = "tomorrow" if i == 1 else day_name.capitalize()
                return {
                    "is_open_now": False,
                    "open_status": f"Closed \u2014 Opens {open_str} {day_label}",
                    "next_change": {"type": "opens", "day": day_name, "time": open_str},
                }
        return {"is_open_now": False, "open_status": "Closed", "next_change": None}


# ── Freshness ──────────────────────────────────────────

def _station_freshness(station: dict) -> dict:
    """Compute freshness status for a station.

    Note: The UK Gov Fuel Finder scheme requires stations to update within
    30 minutes of any *price change*. A station with no update for days may
    simply have a stable price — not necessarily be closed. We use generous
    thresholds to avoid false alarms.
    """
    now = datetime.now(timezone.utc)

    if station.get("is_permanently_closed"):
        return {"status": "closed", "label": "Permanently Closed", "icon": "\u26ab", "hours_since_update": None}
    if station.get("is_temporarily_closed"):
        return {"status": "closed", "label": "Temporarily Closed", "icon": "\u26ab", "hours_since_update": None}

    latest = None
    for p in station.get("prices", []):
        ts_str = p.get("price_last_updated")
        if not ts_str:
            continue
        try:
            ts = datetime.fromisoformat(ts_str.replace("Z", "+00:00"))
            if latest is None or ts > latest:
                latest = ts
        except (ValueError, TypeError):
            continue

    if latest is None:
        return {"status": "stale", "label": "No price data", "icon": "\U0001f534", "hours_since_update": None,
                "detail": "No price data available"}

    hours = (now - latest).total_seconds() / 3600

    if hours < 1:
        return {"status": "fresh", "label": "Verified", "icon": "\U0001f7e2", "hours_since_update": round(hours, 1),
                "detail": "Updated within the hour \u2014 confirmed active"}
    elif hours < 48:
        return {"status": "fresh", "label": "Fresh", "icon": "\U0001f7e2", "hours_since_update": round(hours, 1),
                "detail": "Recently updated \u2014 price likely current"}
    elif hours < 96:
        return {"status": "aging", "label": "Aging", "icon": "\U0001f7e1", "hours_since_update": round(hours, 1),
                "detail": "Not updated in 2+ days \u2014 price may have changed"}
    elif hours < 168:
        return {"status": "stale", "label": "Stale", "icon": "\U0001f534", "hours_since_update": round(hours, 1),
                "detail": "Not updated in 4+ days \u2014 treat price with caution"}
    else:
        return {"status": "stale", "label": "Unverified", "icon": "\U0001f534", "hours_since_update": round(hours, 1),
                "detail": "Not updated in 7+ days \u2014 station may be inactive"}


# ── Supply Health ──────────────────────────────────────

def _supply_health(stations: list) -> dict:
    """Calculate area supply health score. Only counts OPEN stations."""
    open_stations = [s for s in stations if s.get("open_status_data", {}).get("is_open_now") is not False]
    total = len(stations)
    total_open = len(open_stations)

    if total == 0:
        return {"score": 0, "status": "alert", "label": "NO DATA", "emoji": "\U0001f6a8",
                "fresh": 0, "aging": 0, "stale": 0, "closed": 0, "total": 0,
                "total_open": 0, "fresh_pct": 0, "closed_pct": 0}

    fresh = aging = stale = closed_count = 0
    for s in stations:
        f = _station_freshness(s)
        if f["status"] == "fresh":
            fresh += 1
        elif f["status"] == "aging":
            aging += 1
        elif f["status"] == "closed":
            closed_count += 1
        else:
            stale += 1

    base = total_open if total_open > 0 else total
    fresh_pct = (fresh / base) * 100
    closed_pct = (closed_count / total) * 100

    if fresh_pct > 70 and closed_pct < 5:
        status, label, emoji = "normal", "NORMAL", "\u2705"
    elif fresh_pct < 40 or closed_pct > 15:
        status, label, emoji = "alert", "ALERT", "\U0001f6a8"
    else:
        status, label, emoji = "watch", "WATCH", "\u26a0\ufe0f"

    score = round(fresh_pct * 0.8 + (100 - closed_pct * 5) * 0.2)
    score = max(0, min(100, score))

    return {
        "score": score, "status": status, "label": label, "emoji": emoji,
        "fresh": fresh, "aging": aging, "stale": stale, "closed": closed_count,
        "total": total, "total_open": total_open,
        "fresh_pct": round(fresh_pct, 1), "closed_pct": round(closed_pct, 1),
    }


# ── Price Trend Analysis ───────────────────────────────

def _price_trend_analysis(trends: list) -> dict:
    """Analyse price trend data for anomalies and direction."""
    if not trends or len(trends) < 2:
        return {"direction": "stable", "symbol": "\u2192", "change_7d": 0, "anomaly": False, "description": "Insufficient data"}

    recent = trends[-1]
    recent_price = recent.get("avgPricePence", 0)

    week_ago_price = None
    recent_date = recent.get("date", "")
    for t in reversed(trends):
        if t.get("date", "") <= recent_date:
            try:
                rd = datetime.fromisoformat(recent_date)
                td = datetime.fromisoformat(t.get("date", recent_date))
                if (rd - td).days >= 6:
                    week_ago_price = t.get("avgPricePence")
                    break
            except (ValueError, TypeError):
                continue

    if week_ago_price is None and len(trends) >= 2:
        week_ago_price = trends[0].get("avgPricePence", recent_price)

    change_7d = round(recent_price - (week_ago_price or recent_price), 1)

    if change_7d > 2:
        direction, symbol = "rising", "\u2191"
    elif change_7d < -2:
        direction, symbol = "falling", "\u2193"
    else:
        direction, symbol = "stable", "\u2192"

    anomaly = False
    for i in range(1, len(trends)):
        prev = trends[i - 1].get("avgPricePence", 0)
        curr = trends[i].get("avgPricePence", 0)
        if curr - prev > 5:
            anomaly = True
            break

    desc = f"{symbol} {direction.title()} ({change_7d:+.1f}p/week)"
    if anomaly:
        desc += " \u2014 \u26a0\ufe0f Abnormal spike detected"

    return {"direction": direction, "symbol": symbol, "change_7d": change_7d, "anomaly": anomaly, "description": desc}






# -- Traffic Congestion Scoring --------------------------------

def _haversine_km(lat1, lon1, lat2, lon2):
    """Haversine distance in km between two points."""
    from math import radians, sin, cos, sqrt, atan2
    R = 6371
    dlat = radians(lat2 - lat1)
    dlon = radians(lon2 - lon1)
    a = sin(dlat/2)**2 + cos(radians(lat1)) * cos(radians(lat2)) * sin(dlon/2)**2
    return R * 2 * atan2(sqrt(a), sqrt(1-a))


_traffic_cache = {"data": None, "ts": 0}


async def _fetch_congestion_zones():
    """Fetch congestion zones from AyrTraffic, cached 60s."""
    now = time.time()
    if _traffic_cache["data"] and now - _traffic_cache["ts"] < 60:
        return _traffic_cache["data"]
    try:
        async with httpx.AsyncClient(timeout=5) as client:
            resp = await client.get("http://localhost:3876/api/traffic/congestion-zones")
            if resp.status_code == 200:
                data = resp.json()
                _traffic_cache["data"] = data.get("zones", [])
                _traffic_cache["ts"] = now
                return _traffic_cache["data"]
    except Exception:
        pass
    return _traffic_cache["data"] or []


def _score_station_traffic(station_lat, station_lon, zones):
    """Score traffic near a fuel station. Returns 0 (clear) to 1 (gridlocked)."""
    if not zones:
        return {"score": 0, "status": "clear", "nearby_incidents": 0, "detail": "No traffic data"}

    max_congestion = 0
    nearby_incidents = 0
    nearest_zone = None

    RADIUS_KM = 1.5  # 1.5km radius

    for zone in zones:
        dist = _haversine_km(station_lat, station_lon, zone["lat"], zone["lon"])
        if dist <= RADIUS_KM:
            # Weight by proximity - closer zones matter more
            proximity_weight = 1 - (dist / RADIUS_KM)
            effective_congestion = zone.get("congestion", 0) * proximity_weight

            if effective_congestion > max_congestion:
                max_congestion = effective_congestion
                nearest_zone = zone

            if zone.get("type") == "incident":
                nearby_incidents += 1

    score = round(min(1.0, max_congestion), 2)

    if score > 0.6:
        status = "heavy"
        detail = "Heavy traffic nearby"
    elif score > 0.3:
        status = "moderate"
        detail = "Moderate traffic nearby"
    elif score > 0:
        status = "light"
        detail = "Light traffic nearby"
    else:
        status = "clear"
        detail = "No congestion detected"

    if nearest_zone and nearest_zone.get("route"):
        detail += f" ({nearest_zone['route']})"

    return {
        "score": score,
        "status": status,
        "nearby_incidents": nearby_incidents,
        "detail": detail,
    }


# -- Price Forecast (Weighted Linear Regression) --------

def _generate_forecast(trends: list, days_ahead: int = 14) -> dict:
    """Generate price forecast using weighted linear regression.
    
    Uses last 30 days with exponential weighting (recent data weighted more).
    Returns predicted prices for next N days with confidence bands.
    """
    if not trends or len(trends) < 7:
        return {"available": False, "reason": "Need at least 7 days of history"}

    window = trends[-30:]
    
    try:
        base_date = datetime.fromisoformat(window[0]["date"])
    except (ValueError, KeyError):
        return {"available": False, "reason": "Invalid date format"}
    
    points = []
    for t in window:
        try:
            d = datetime.fromisoformat(t["date"])
            x = (d - base_date).days
            y = t.get("avgPricePence", 0)
            if y > 0:
                points.append((x, y))
        except (ValueError, KeyError, TypeError):
            continue
    
    if len(points) < 7:
        return {"available": False, "reason": "Insufficient valid data points"}
    
    n = len(points)
    
    # Exponential weights - recent data ~7x more important than oldest
    weights = [math.exp(2.0 * i / n) for i in range(n)]
    
    # Weighted linear regression: y = a + b*x
    sum_w = sum(weights)
    sum_wx = sum(w * p[0] for w, p in zip(weights, points))
    sum_wy = sum(w * p[1] for w, p in zip(weights, points))
    sum_wxx = sum(w * p[0]**2 for w, p in zip(weights, points))
    sum_wxy = sum(w * p[0] * p[1] for w, p in zip(weights, points))
    
    denom = sum_w * sum_wxx - sum_wx**2
    if abs(denom) < 1e-10:
        return {"available": False, "reason": "Degenerate data"}
    
    b = (sum_w * sum_wxy - sum_wx * sum_wy) / denom
    a = (sum_wy - b * sum_wx) / sum_w
    
    # Residual standard error
    residuals = [(p[1] - (a + b * p[0]))**2 * w for w, p in zip(weights, points)]
    rmse = math.sqrt(sum(residuals) / sum_w)
    
    # 7-day momentum (short-term acceleration)
    recent_7 = points[-7:]
    if len(recent_7) >= 2:
        momentum = (recent_7[-1][1] - recent_7[0][1]) / max(1, recent_7[-1][0] - recent_7[0][0])
    else:
        momentum = b
    
    # Blend: 60% regression + 40% momentum
    blended_slope = 0.6 * b + 0.4 * momentum
    
    # Sanity cap: UK fuel rarely moves more than 3p/week (~0.43p/day)
    max_slope = 0.43  # ~3p per week
    blended_slope = max(-max_slope, min(max_slope, blended_slope))
    
    last_date = datetime.fromisoformat(window[-1]["date"])
    last_actual = points[-1][1]
    
    forecast_points = []
    for day in range(1, days_ahead + 1):
        forecast_date = last_date + timedelta(days=day)
        predicted = last_actual + blended_slope * day
        confidence = rmse * math.sqrt(1 + day / n) * 1.96
        forecast_points.append({
            "date": forecast_date.strftime("%Y-%m-%d"),
            "predicted": round(predicted, 1),
            "upper": round(predicted + confidence, 1),
            "lower": round(predicted - confidence, 1),
            "day": day,
        })
    
    pred_7d = forecast_points[6] if len(forecast_points) >= 7 else forecast_points[-1]
    pred_14d = forecast_points[-1]
    weekly_change = round(blended_slope * 7, 1)
    
    if weekly_change > 0.5:
        outlook = "rising"
        advice = "Prices trending up — consider filling up soon"
    elif weekly_change < -0.5:
        outlook = "falling"
        advice = "Prices trending down — worth waiting if you can"
    else:
        outlook = "stable"
        advice = "Prices steady — fill up when convenient"
    
    return {
        "available": True,
        "method": "Weighted linear regression (30-day, exponential recency bias)",
        "slope_per_day": round(blended_slope, 3),
        "weekly_change": weekly_change,
        "rmse": round(rmse, 2),
        "outlook": outlook,
        "advice": advice,
        "prediction_7d": {"date": pred_7d["date"], "price": pred_7d["predicted"], "range": [pred_7d["lower"], pred_7d["upper"]]},
        "prediction_14d": {"date": pred_14d["date"], "price": pred_14d["predicted"], "range": [pred_14d["lower"], pred_14d["upper"]]},
        "data_points": n,
        "confidence": "high" if n >= 25 and rmse < 2 else "medium" if n >= 14 and rmse < 4 else "low",
        "points": forecast_points,
    }

# ── Latest Sighting ────────────────────────────────────

def _latest_sighting(station_id: str) -> dict | None:
    """Get the most recent sighting in the last 24h for a station."""
    conn = sqlite3.connect(DB_PATH)
    conn.row_factory = sqlite3.Row
    cutoff = (datetime.now(timezone.utc) - timedelta(hours=24)).isoformat()
    row = conn.execute(
        "SELECT * FROM sightings WHERE station_id=? AND timestamp>? ORDER BY timestamp DESC LIMIT 1",
        (station_id, cutoff)
    ).fetchone()
    conn.close()
    if not row:
        return None
    ts = datetime.fromisoformat(row["timestamp"])
    minutes_ago = int((datetime.now(timezone.utc) - ts).total_seconds() / 60)
    return {
        "minutes_ago": minutes_ago,
        "has_fuel": bool(row["has_fuel"]),
        "queue_length": row["queue_length"],
        "note": row["note"],
    }


# ── Congestion History Background Task ─────────────────

async def _log_congestion_history():
    """Background task: every 10 minutes, log traffic scores for all stations."""
    while True:
        try:
            await asyncio.sleep(600)  # 10 minutes
            zones = await _fetch_congestion_zones()
            if not zones:
                continue

            station_data = await _fetch("/stations", {
                "lat": DEFAULT_LAT, "lon": DEFAULT_LON,
                "radius": DEFAULT_RADIUS, "fuel": "E10", "sort": "price",
            })
            stations = station_data.get("stations", [])
            if not stations:
                continue

            now_uk = datetime.now(UK_TZ).isoformat()
            rows = []
            for s in stations:
                node_id = s.get("node_id")
                if not node_id:
                    continue
                lat = s.get("lat", s.get("location", {}).get("latitude", 0))
                lon = s.get("lon", s.get("location", {}).get("longitude", 0))
                traffic = _score_station_traffic(lat, lon, zones)
                if traffic["score"] > 0:
                    rows.append((node_id, now_uk, traffic["score"], traffic["status"], traffic["nearby_incidents"]))

            if rows:
                conn = sqlite3.connect(DB_PATH)
                conn.executemany(
                    "INSERT INTO congestion_history (station_id, timestamp, score, status, nearby_incidents) VALUES (?,?,?,?,?)",
                    rows,
                )
                conn.commit()
                conn.close()
        except Exception:
            pass  # Keep the task alive


@app.on_event("startup")
async def startup_congestion_logger():
    asyncio.create_task(_log_congestion_history())


# ── Congestion History API ─────────────────────────────

@app.get("/api/station/{node_id}/congestion-history")
async def congestion_history(node_id: str, days: int = 7):
    """Return historical congestion scores, hourly patterns, and 24h prediction."""
    conn = sqlite3.connect(DB_PATH)
    conn.row_factory = sqlite3.Row
    cutoff = (datetime.now(UK_TZ) - timedelta(days=days)).isoformat()

    rows = conn.execute(
        "SELECT timestamp, score, status, nearby_incidents FROM congestion_history WHERE station_id=? AND timestamp>=? ORDER BY timestamp ASC",
        (node_id, cutoff),
    ).fetchall()
    conn.close()

    if not rows:
        return JSONResponse({
            "station_id": node_id,
            "days": days,
            "history": [],
            "patterns": [],
            "prediction_24h": [],
            "message": "No congestion history yet. Data is collected every 10 minutes.",
        })

    # Raw history
    history = [
        {"timestamp": r["timestamp"], "score": r["score"], "status": r["status"], "nearby_incidents": r["nearby_incidents"]}
        for r in rows
    ]

    # Hourly averages grouped by (day_of_week, hour)
    from collections import defaultdict
    bucket = defaultdict(list)  # (dow, hour) -> [scores]
    for r in rows:
        try:
            ts = datetime.fromisoformat(r["timestamp"])
            dow = ts.weekday()  # 0=Mon
            hour = ts.hour
            bucket[(dow, hour)].append(r["score"])
        except (ValueError, TypeError):
            continue

    patterns = []
    for (dow, hour), scores in sorted(bucket.items()):
        avg = round(sum(scores) / len(scores), 3)
        if avg > 0.6:
            level = "heavy"
        elif avg > 0.3:
            level = "moderate"
        elif avg > 0:
            level = "light"
        else:
            level = "clear"
        patterns.append({
            "day_of_week": dow,
            "day_name": DAY_NAMES[dow].capitalize(),
            "hour": hour,
            "avg_score": avg,
            "level": level,
            "sample_count": len(scores),
        })

    # Prediction for next 24 hours based on historical pattern
    now_uk = datetime.now(UK_TZ)
    prediction = []
    for offset_h in range(24):
        target = now_uk + timedelta(hours=offset_h)
        dow = target.weekday()
        hour = target.hour
        scores = bucket.get((dow, hour), [])
        if scores:
            pred_score = round(sum(scores) / len(scores), 3)
        else:
            # Fall back to same hour any day
            all_same_hour = []
            for (d, h), sc in bucket.items():
                if h == hour:
                    all_same_hour.extend(sc)
            pred_score = round(sum(all_same_hour) / len(all_same_hour), 3) if all_same_hour else 0

        if pred_score > 0.6:
            level = "heavy"
        elif pred_score > 0.3:
            level = "moderate"
        elif pred_score > 0:
            level = "light"
        else:
            level = "clear"

        prediction.append({
            "time": target.strftime("%Y-%m-%d %H:00"),
            "day_name": DAY_NAMES[dow].capitalize(),
            "hour": hour,
            "predicted_score": pred_score,
            "level": level,
            "confidence": "high" if len(scores) >= 6 else "medium" if len(scores) >= 2 else "low",
        })

    return JSONResponse({
        "station_id": node_id,
        "days": days,
        "total_records": len(history),
        "history": history,
        "patterns": patterns,
        "prediction_24h": prediction,
    })


# ── Pages ──────────────────────────────────────────────

@app.get("/")
async def index():
    return FileResponse(Path(__file__).parent / "index.html", media_type="text/html")


@app.get("/static/{filepath:path}")
async def serve_static(filepath: str):
    file_path = Path(__file__).parent / "static" / filepath
    if file_path.exists():
        return FileResponse(file_path)
    raise HTTPException(status_code=404, detail="Not found")


# ── API Proxies ────────────────────────────────────────

@app.get("/api/stations")
async def stations(
    lat: float = DEFAULT_LAT,
    lon: float = DEFAULT_LON,
    radius: int = DEFAULT_RADIUS,
    fuel: str = "E10",
    sort: str = "price",
):
    data = await _fetch("/stations", {
        "lat": lat, "lon": lon, "radius": radius, "fuel": fuel, "sort": sort,
    })
    zones = await _fetch_congestion_zones()
    for s in data.get("stations", []):
        s["freshness"] = _station_freshness(s)
        open_data = _compute_open_status(s)
        s["open_status_data"] = open_data
        s["is_open_now"] = open_data["is_open_now"]
        s["open_status"] = open_data["open_status"]
        s["next_change"] = open_data["next_change"]
        s["latest_sighting"] = _latest_sighting(s.get("node_id", ""))
        s["traffic"] = _score_station_traffic(
            s.get("lat", s.get("location", {}).get("latitude", 0)), s.get("lon", s.get("location", {}).get("longitude", 0)), zones
        )
    data["supply_health"] = _supply_health(data.get("stations", []))
    return data


@app.get("/api/history/{node_id}")
async def history(node_id: str, fuel: str = "E10", days: int = 30):
    return await _fetch(f"/stations/{node_id}/history", {"fuel": fuel, "days": days})


@app.get("/api/trends")
async def trends(
    type: str = "city",
