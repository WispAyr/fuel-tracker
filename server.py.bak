    import uvicorn
    parser = argparse.ArgumentParser()
    parser.add_argument("--port", type=int, default=3971)
    parser.add_argument("--host", type=str, default="0.0.0.0")
    args = parser.parse_args()
    uvicorn.run(app, host=args.host, port=args.port)
