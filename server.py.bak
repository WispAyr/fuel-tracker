@app.get("/api/crude")
async def crude_oil():
    """Fetch live Brent crude oil price from Yahoo Finance + USD/GBP rate."""
    try:
        import asyncio as _asyncio
        async with httpx.AsyncClient(timeout=10) as client:
            yahoo_req = client.get(
                "https://query1.finance.yahoo.com/v8/finance/chart/BZ=F?interval=1d&range=5d",
                headers={"User-Agent": "Mozilla/5.0"},
            )
            fx_req = client.get("https://open.er-api.com/v6/latest/USD")
            yahoo_resp, fx_resp = await _asyncio.gather(yahoo_req, fx_req, return_exceptions=True)

        price_usd = day_high = day_low = prev_close = week52_high = week52_low = None

        if not isinstance(yahoo_resp, Exception) and yahoo_resp.status_code == 200:
            meta = yahoo_resp.json().get("chart", {}).get("result", [{}])[0].get("meta", {})
            price_usd = meta.get("regularMarketPrice")
            day_high = meta.get("regularMarketDayHigh")
            day_low = meta.get("regularMarketDayLow")
            prev_close = meta.get("chartPreviousClose")
            week52_high = meta.get("fiftyTwoWeekHigh")
            week52_low = meta.get("fiftyTwoWeekLow")

        gbp_rate = 0.79
        if not isinstance(fx_resp, Exception) and fx_resp.status_code == 200:
            gbp_rate = fx_resp.json().get("rates", {}).get("GBP", 0.79)

        if price_usd is not None:
            price_gbp = round(price_usd * gbp_rate, 2)
            change = round(price_usd - (prev_close or price_usd), 2) if prev_close else None
            change_pct = round((change / prev_close) * 100, 2) if change and prev_close else None
            return {
                "available": True,
                "price_usd": round(price_usd, 2),
                "price_gbp": price_gbp,
                "gbp_rate": round(gbp_rate, 4),
                "day_high": round(day_high, 2) if day_high else None,
                "day_low": round(day_low, 2) if day_low else None,
                "change": change,
                "change_pct": change_pct,
                "prev_close": round(prev_close, 2) if prev_close else None,
                "week52_high": round(week52_high, 2) if week52_high else None,
                "week52_low": round(week52_low, 2) if week52_low else None,
                "link": "https://oilprice.com/oil-price-charts/",
                "context": "Brent Crude affects UK pump prices with ~2 week lag",
            }
        else:
            return {
                "available": False,
                "gbp_rate": round(gbp_rate, 4),
                "message": "Crude price temporarily unavailable",
                "link": "https://oilprice.com/oil-price-charts/",
            }
    except Exception:
        return {
            "available": False,
            "link": "https://oilprice.com/oil-price-charts/",
            "message": "Could not fetch crude data",
        }


# ── Community Sightings ────────────────────────────────

class SightingBody(BaseModel):
    station_id: str
    has_fuel: bool
    queue_length: str
    note: str | None = None


@app.post("/api/sighting")
async def post_sighting(body: SightingBody, request: Request):
    if body.queue_length not in ("none", "short", "long"):
        raise HTTPException(status_code=422, detail="queue_length must be none/short/long")

    client_ip = request.client.host if request.client else "unknown"
    forwarded = request.headers.get("x-forwarded-for", "")
    real_ip = forwarded.split(",")[0].strip() if forwarded else client_ip
    ip_hash = hashlib.sha256(real_ip.encode()).hexdigest()

    conn = sqlite3.connect(DB_PATH)
    cutoff = (datetime.now(timezone.utc) - timedelta(minutes=15)).isoformat()
    existing = conn.execute(
        "SELECT id FROM sightings WHERE station_id=? AND ip_hash=? AND timestamp>?",
        (body.station_id, ip_hash, cutoff)
    ).fetchone()

    if existing:
        conn.close()
        raise HTTPException(status_code=429, detail="You've already reported this station recently. Please wait 15 minutes.")

    note = (body.note or "").strip()[:100] or None
    now_ts = datetime.now(timezone.utc).isoformat()
    conn.execute(
        "INSERT INTO sightings (station_id, timestamp, ip_hash, has_fuel, queue_length, note) VALUES (?,?,?,?,?,?)",
        (body.station_id, now_ts, ip_hash, int(body.has_fuel), body.queue_length, note)
    )
    conn.commit()
    conn.close()

    return {"ok": True, "message": "Thanks! Your report helps others."}


@app.get("/api/sightings")
async def get_sightings(station_id: str):
    conn = sqlite3.connect(DB_PATH)
    conn.row_factory = sqlite3.Row
    cutoff = (datetime.now(timezone.utc) - timedelta(hours=24)).isoformat()
    rows = conn.execute(
        "SELECT timestamp, has_fuel, queue_length, note FROM sightings WHERE station_id=? AND timestamp>? ORDER BY timestamp DESC",
        (station_id, cutoff)
    ).fetchall()
    conn.close()

    now = datetime.now(timezone.utc)
    result = []
    for r in rows:
        ts = datetime.fromisoformat(r["timestamp"])
        mins = int((now - ts).total_seconds() / 60)
        result.append({
            "minutes_ago": mins,
            "has_fuel": bool(r["has_fuel"]),
            "queue_length": r["queue_length"],
            "note": r["note"],
        })
    return {"sightings": result, "count": len(result)}



@app.get("/api/station-traffic")
async def station_traffic():
    """Fuel stations enriched with live traffic congestion scores."""
    zones = await _fetch_congestion_zones()
    station_data = await _fetch("/stations", {
        "lat": DEFAULT_LAT, "lon": DEFAULT_LON,
        "radius": DEFAULT_RADIUS, "fuel": "E10", "sort": "price",
    })

    results = []
    for s in station_data.get("stations", []):
        lat = s.get("latitude", 0)
        lon = s.get("longitude", 0)
        traffic = _score_station_traffic(lat, lon, zones)

        # Get cheapest E10 price
        e10_price = None
        for p in s.get("prices", []):
            if p.get("fuel_type") == "E10" and p.get("price"):
                e10_price = p["price"]
                break

        results.append({
            "name": s.get("trading_name") or s.get("name", "Unknown"),
            "lat": lat,
            "lon": lon,
            "e10_price": e10_price,
            "traffic": traffic,
            "open_status": _compute_open_status(s).get("open_status"),
        })

    # Sort by combined score: cheapest + least congested
    results.sort(key=lambda x: (x["e10_price"] or 999) + (x["traffic"]["score"] * 5))

    return JSONResponse({
        "stations": results,
        "zones_active": len(zones),
        "recommendation": results[0] if results else None,
    })


# ── Nuro integration (v2.0 streams format) ─────────────

@app.get("/api/nuro")
async def nuro():
    """Compact summary for nuro dashboard — v2.0 streams format."""
    stations_data = await _fetch("/stations", {
        "lat": DEFAULT_LAT, "lon": DEFAULT_LON,
        "radius": DEFAULT_RADIUS, "fuel": "E10", "sort": "price",
    })
    all_stations = stations_data.get("stations", [])
    if not all_stations:
        return JSONResponse({"error": "No station data available"}, status_code=503)

    for s in all_stations:
        s["open_status_data"] = _compute_open_status(s)

    cheapest_e10 = 9999
    cheapest_diesel = 9999
    e10_prices, diesel_prices = [], []

    for s in all_stations:
        for p in s.get("prices", []):
            ft, price = p.get("fuel_type", ""), p.get("price")
            if price is None:
                continue
            if ft == "E10":
                e10_prices.append(price)
                if price < cheapest_e10:
                    cheapest_e10 = price
            elif ft == "B7_STANDARD":
                diesel_prices.append(price)
                if price < cheapest_diesel:
                    cheapest_diesel = price

    avg_e10 = round(sum(e10_prices) / len(e10_prices), 1) if e10_prices else None
    avg_diesel = round(sum(diesel_prices) / len(diesel_prices), 1) if diesel_prices else None
    health = _supply_health(all_stations)

    try:
        trend_data = await _fetch("/prices/history", {"type": "city", "name": "Ayr", "fuel": "E10", "days": 14})
        analysis = _price_trend_analysis(trend_data.get("trends", []))
    except Exception:
        analysis = {"direction": "stable", "change_7d": 0, "symbol": "\u2192"}

    trend_colors = {"rising": "#ef4444", "falling": "#22c55e", "stable": "#3b82f6"}
    health_colors = {"normal": "#22c55e", "watch": "#f59e0b", "alert": "#ef4444"}

    streams = [
        {
            "id": "cheapest_e10",
            "label": "Cheapest E10",
            "type": "stat",
            "value": round(cheapest_e10, 1) if cheapest_e10 < 9999 else None,
            "unit": "p/L",
            "color": "#22c55e",
        },
        {
            "id": "cheapest_diesel",
            "label": "Cheapest Diesel",
            "type": "stat",
            "value": round(cheapest_diesel, 1) if cheapest_diesel < 9999 else None,
            "unit": "p/L",
            "color": "#3b82f6",
        },
        {
            "id": "avg_e10",
            "label": "Avg E10",
            "type": "gauge",
            "value": avg_e10,
            "unit": "p/L",
            "min": 120,
            "max": 200,
            "color": "#f59e0b",
        },
        {
            "id": "supply_health",
            "label": "Supply Health",
            "type": "gauge",
            "value": health["score"],
            "unit": "%",
            "min": 0,
            "max": 100,
            "color": health_colors.get(health["status"], "#22c55e"),
        },
        {
            "id": "stations_open",
            "label": "Stations Open",
            "type": "stat",
            "value": health.get("total_open", 0),
            "unit": f"of {health['total']}",
            "color": "#06b6d4",
        },
        {
            "id": "price_trend",
            "label": "7-Day Trend",
            "type": "stat",
            "value": analysis.get("change_7d", 0),
            "unit": "p/wk",
            "color": trend_colors.get(analysis["direction"], "#3b82f6"),
        },
    ]

    # Fetch traffic data for station impact
    try:
        zones = await _fetch_congestion_zones()
        impacted = sum(1 for s in all_stations if _score_station_traffic(
            s.get("lat", s.get("location", {}).get("latitude", 0)), s.get("lon", s.get("location", {}).get("longitude", 0)), zones
        )["score"] > 0.3)
        streams.append({
            "id": "traffic_impact",
            "label": "Stations in Traffic",
            "type": "stat",
            "value": impacted,
            "unit": f"of {len(all_stations)}",
            "color": "#ef4444" if impacted > 3 else "#f59e0b" if impacted > 0 else "#22c55e",
        })
    except Exception:
        pass

    return JSONResponse({
        "version": "2.0",
        "label": "FuelPulse",
        "icon": "\u26fd",
        "description": f"Ayrshire fuel prices \u2014 {health['total']} stations, {health.get('total_open', 0)} open",
        "streams": streams,
        "updated_at": datetime.now(timezone.utc).isoformat(),
    })


