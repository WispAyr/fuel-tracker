        order: 3,
        yAxisID: 'y'
      });
    }

    // Diesel forecast
    if (dieselForecastLine.length) {
      datasets.push({
        label: 'Diesel Forecast',
        data: dieselForecastLine,
        borderColor: '#60a5fa',
        borderDash: [8, 5],
        backgroundColor: 'transparent',
        fill: false,
        tension: 0.3,
        borderWidth: 2.5,
        pointRadius: 0,
        pointHoverRadius: 5,
        order: 1,
        yAxisID: 'y2'
      });
      datasets.push({
        label: '_dieselupper',
        data: dieselUpperBand,
        borderColor: 'rgba(96,165,250,.3)',
        borderWidth: 1,
        borderDash: [3, 3],
        backgroundColor: 'rgba(37,99,235,.06)',
        fill: '+1',
        tension: 0.3,
        pointRadius: 0,
        pointHoverRadius: 0,
        order: 3,
        yAxisID: 'y2'
      });
      datasets.push({
        label: '_diesellower',
        data: dieselLowerBand,
        borderColor: 'rgba(96,165,250,.3)',
        borderWidth: 1,
        borderDash: [3, 3],
        backgroundColor: 'transparent',
        fill: false,
        tension: 0.3,
        pointRadius: 0,
        pointHoverRadius: 0,
        order: 3,
        yAxisID: 'y2'
      });
    }

    // Annotation: "Today" vertical line
    const annotationOpts = {};
    if (todayStr && e10ForecastLine.length) {
      annotationOpts.annotations = {
        todayLine: {
          type: 'line',
          xMin: todayStr,
          xMax: todayStr,
          borderColor: 'rgba(255,255,255,.35)',
          borderWidth: 2,
          borderDash: [4, 4],
          label: {
            display: true,
            content: 'Today',
            position: 'start',
            backgroundColor: 'rgba(255,255,255,.12)',
            color: 'rgba(255,255,255,.7)',
            font: { size: 11, weight: '600' },
            padding: { top: 3, bottom: 3, left: 8, right: 8 },
            borderRadius: 4
          }
        }
      };
    }

    trendChart = new Chart(ctx, {
      type: 'line',
      data: { datasets },
      options: {
        responsive: true, maintainAspectRatio: false,
        scales: {
          x: {
            type: 'time',
            time: { unit: 'week', displayFormats: { week: 'd MMM', day: 'd MMM', month: 'MMM yyyy' } },
            grid: { display: false },
            ticks: { color: '#9ca3af', maxTicksLimit: 12 }
          },
          y: {
            type: 'linear',
            position: 'left',
            title: { display: true, text: 'E10 (p/litre)', color: '#16a34a', font: { size: 12, weight: '600' } },
            grid: { color: 'rgba(255,255,255,.04)' },
            ticks: { color: '#16a34a' },
            suggestedMin: (() => {
              const allY = [...e10Points, ...e10ForecastLine, ...e10LowerBand].map(p => p.y).filter(v => v > 0);
              return allY.length ? Math.floor(Math.min(...allY) - 2) : undefined;
            })(),
            suggestedMax: (() => {
              const allY = [...e10Points, ...e10ForecastLine, ...e10UpperBand].map(p => p.y).filter(v => v > 0);
              return allY.length ? Math.ceil(Math.max(...allY) + 2) : undefined;
            })()
          },
          y2: {
            type: 'linear',
            position: 'right',
            title: { display: true, text: 'Diesel (p/litre)', color: '#2563eb', font: { size: 12, weight: '600' } },
            grid: { drawOnChartArea: false },
            ticks: { color: '#2563eb' },
            suggestedMin: (() => {
              const allY = [...dieselPoints, ...dieselForecastLine, ...dieselLowerBand].map(p => p.y).filter(v => v > 0);
              return allY.length ? Math.floor(Math.min(...allY) - 2) : undefined;
            })(),
            suggestedMax: (() => {
              const allY = [...dieselPoints, ...dieselForecastLine, ...dieselUpperBand].map(p => p.y).filter(v => v > 0);
              return allY.length ? Math.ceil(Math.max(...allY) + 2) : undefined;
            })()
          }
        },
        plugins: {
          legend: {
            position: 'top',
            labels: {
              usePointStyle: true,
              pointStyle: 'circle',
              padding: 16,
              filter: function(item) {
                return !item.text.startsWith('_') && !item.text.includes('95%');
              },
              generateLabels: function(chart) {
                const orig = Chart.defaults.plugins.legend.labels.generateLabels(chart);
                return orig.filter(l => !l.text.startsWith('_') && !l.text.includes('95%')).map(l => {
                  if (l.text.includes('Forecast')) {
                    l.lineDash = [6, 3];
                  }
                  return l;
                });
              }
            }
          },
          tooltip: {
            mode: 'nearest',
            intersect: false,
            filter: function(item) {
              return !item.dataset.label.startsWith('_') && !item.dataset.label.includes('95%');
            },
            callbacks: {
              title: function(items) {
                if (!items.length) return '';
                const d = new Date(items[0].parsed.x);
                return d.toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' });
              },
              label: function(ctx) {
                const lbl = ctx.dataset.label;
                const val = ctx.parsed.y;
                if (lbl.includes('Forecast')) return `${lbl}: ${val.toFixed(1)}p (predicted)`;
                return `${lbl}: ${val.toFixed(1)}p`;
              }
            }
          },
          annotation: annotationOpts
        },
        interaction: { mode: 'nearest', intersect: false, axis: 'x' }
      }
    });
  } catch (e) {
    console.error('Trends load failed:', e);
  }
}

async function loadStats() {
  try {
    const data = await fetch('/api/stats').then(r => r.json());

    const bestDayData = data.best_day?.data?.E10?.bestDay;
    const worstDayData = data.best_day?.data?.E10?.worstDay;
    const allDays = data.best_day?.data?.E10?.allDays || [];

    if (bestDayData) {
      document.getElementById('bestDay').textContent = bestDayData.dayName;
      const saving = worstDayData ? (worstDayData.avgPricePence - bestDayData.avgPricePence).toFixed(1) : '?';
      document.getElementById('bestDayDetail').textContent = `~${saving}p cheaper than ${worstDayData?.dayName || 'worst day'}`;
      document.getElementById('tipBestDay').textContent = bestDayData.dayName;
      document.getElementById('tipBestDayDetail').textContent = `Fill up ${bestDayData.dayName} to save ~${saving}p/litre vs ${worstDayData?.dayName}`;
    }
    if (worstDayData) {
      document.getElementById('tipWorstDay').textContent = worstDayData.dayName;
      document.getElementById('tipWorstDayDetail').textContent = `Average ${worstDayData.avgPricePence.toFixed(1)}p nationally — avoid if you can`;
    }

    if (allDays.length) {
      const dayNames = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];
      const sortedDays = [...allDays].sort((a,b) => a.dayOfWeek - b.dayOfWeek);
      const ctx = document.getElementById('dayChart').getContext('2d');
      if (dayChart) dayChart.destroy();
      dayChart = new Chart(ctx, {
        type: 'bar',
        data: {
          labels: sortedDays.map(d => dayNames[d.dayOfWeek]),
          datasets: [{
            label: 'Avg E10 (p)',
            data: sortedDays.map(d => d.avgPricePence),
            backgroundColor: sortedDays.map(d =>
              d.dayOfWeek === bestDayData?.dayOfWeek ? '#16a34a' :
              d.dayOfWeek === worstDayData?.dayOfWeek ? '#dc2626' : '#93c5fd'
            ),
            borderRadius: 6,
            borderSkipped: false
          }]
        },
        options: {
          responsive: true, maintainAspectRatio: false,
          scales: {
            y: { beginAtZero: false, grid: { color: 'rgba(0,0,0,.04)' }, ticks: { color: '#9ca3af' } },
            x: { grid: { display: false }, ticks: { color: '#9ca3af' } }
          },
          plugins: { legend: { display: false } }
        }
      });
    }

    const brands = (data.brands?.brands || []).slice(0, 10).filter(b => b.averageE10);
    if (brands.length) {
      const sortedBrands = [...brands].sort((a, b) => a.averageE10 - b.averageE10);
      document.getElementById('tipBrand').textContent = sortedBrands[0].name;
      document.getElementById('tipBrandDetail').textContent = `${sortedBrands[0].averageE10}p E10, ${sortedBrands[0].averageDiesel}p diesel nationally`;

      const ctx = document.getElementById('brandChart').getContext('2d');
      if (brandChart) brandChart.destroy();
      brandChart = new Chart(ctx, {
        type: 'bar',
        data: {
          labels: sortedBrands.map(b => b.name),
          datasets: [
            { label: 'E10', data: sortedBrands.map(b => b.averageE10), backgroundColor: '#4ade80', borderRadius: 4, borderSkipped: false },
            { label: 'Diesel', data: sortedBrands.map(b => b.averageDiesel), backgroundColor: '#60a5fa', borderRadius: 4, borderSkipped: false }
          ]
        },
        options: {
          responsive: true, maintainAspectRatio: false, indexAxis: 'y',
          scales: {
            x: { beginAtZero: false, grid: { color: 'rgba(0,0,0,.04)' }, ticks: { color: '#9ca3af' } },
            y: { grid: { display: false }, ticks: { color: '#9ca3af', font: { size: 11 } } }
          },
          plugins: { legend: { position: 'top', labels: { usePointStyle: true } } }
        }
      });
    }
  } catch (e) {
    console.error('Stats load failed:', e);
  }
}

async function loadCrude() {
  try {
    const data = await fetch('/api/crude').then(r => r.json());
    const info = document.getElementById('crudeInfo');
    const stats = document.getElementById('crudeStats');
    if (data.available) {
      const changeStr = data.change != null
        ? `${data.change >= 0 ? '+' : ''}${data.change.toFixed(2)} (${data.change_pct >= 0 ? '+' : ''}${data.change_pct}%)`
        : '';
      const changeColor = data.change > 0 ? 'var(--w-red)' : data.change < 0 ? 'var(--w-green)' : 'var(--w-text-muted)';
      info.innerHTML = `<span style="font-size:18px;font-weight:800;color:var(--w-text)">$${data.price_usd}</span> <span style="font-size:13px;color:var(--w-text-muted)">/barrel</span> <span style="font-size:13px;font-weight:600;color:${changeColor};margin-left:6px">${changeStr}</span>`;
      stats.style.display = 'flex';
      stats.innerHTML = `
        <span style="font-size:12px;color:var(--w-text-muted)">£${data.price_gbp}</span>
        <span style="font-size:11px;color:var(--w-text-light)" title="Today's range">L $${data.day_low || '?'} / H $${data.day_high || '?'}</span>
        <a href="${data.link}" target="_blank" style="font-size:11px;color:var(--w-blue);text-decoration:none;font-weight:500">Chart →</a>
      `;
    } else {
      info.innerHTML = `${data.message}. <a href="${data.link}" target="_blank">Check live →</a>`;
      stats.style.display = 'none';
    }
  } catch (e) {
    document.getElementById('crudeInfo').textContent = 'Crude data unavailable';
  }
}

// ── Refresh with animation ──
function refreshAll(btn) {
  if (btn) btn.classList.add('spinning');
  Promise.all([loadStations(), loadTrends(), loadStats(), loadCrude(), loadPrism()]).finally(() => {
    if (btn) btn.classList.remove('spinning');
  });
}

// ── Prism Intelligence ─────────────────────────────────────────
const PRISM_API = 'https://artemis.wispayr.online/api';
let _fuelPrism = null;

async function loadPrism() {
  try {
    const res = await fetch(`${PRISM_API}/fuel`);
    if (!res.ok) return;
    const body = await res.json();
    if (!body.data) return;
    _fuelPrism = body.data;
    renderPrism(body.data);
  } catch (e) { console.debug('Prism load failed:', e); }
}

function renderPrism(d) {
  const grid = document.getElementById('prismGrid');
  if (!grid) return;
  const gapColor = d.gap_status === 'wide' ? '#f59e0b' : d.gap_status === 'elevated' ? '#eab308' : '#22c55e';
  const mediumTank = d.tanks.find(t => t.size_l === 55) || d.tanks[1];
  const monthly1000 = d.monthly_estimates.find(m => m.miles === 1000) || d.monthly_estimates[1];
  const petrolArrow = d.petrol_change_weekly > 0.5 ? '↑' : d.petrol_change_weekly < -0.5 ? '↓' : '→';
  const dieselArrow = d.diesel_change_weekly > 0.5 ? '↑' : d.diesel_change_weekly < -0.5 ? '↓' : '→';

  grid.innerHTML = `
    <div class="prism-card" onclick="explainPrism('national')">
      <div class="prism-label">🇬🇧 UK National Average</div>
      <div class="prism-value">${d.petrol_ppl}p <span style="color:var(--w-text-muted);font-size:14px">/ ${d.diesel_ppl}p</span></div>
      <div class="prism-sub">Petrol ${petrolArrow} ${d.petrol_change_weekly > 0 ? '+' : ''}${d.petrol_change_weekly}p · Diesel ${dieselArrow} ${d.diesel_change_weekly > 0 ? '+' : ''}${d.diesel_change_weekly}p</div>
      <div class="prism-meta">Weekly change from last BEIS update</div>
    </div>
    <div class="prism-card" onclick="explainPrism('tank')">
      <div class="prism-label">⛽ Tank Fill Cost</div>
      <div class="prism-value">£${mediumTank.petrol_cost}</div>
      <div class="prism-sub">medium car (55L) petrol · £${mediumTank.diesel_cost} diesel</div>
      <div class="prism-meta">${d.tanks[0].label}: £${d.tanks[0].petrol_cost} · ${d.tanks[2].label}: £${d.tanks[2].petrol_cost}</div>
    </div>
    <div class="prism-card" onclick="explainPrism('monthly')">
      <div class="prism-label">💰 Monthly Cost (1000mi)</div>
      <div class="prism-value">£${monthly1000.petrol_monthly}</div>
      <div class="prism-sub">petrol medium car · £${monthly1000.diesel_monthly} diesel</div>
      <div class="prism-meta">Annual: £${monthly1000.annual_petrol} petrol / £${monthly1000.annual_diesel} diesel</div>
    </div>
    <div class="prism-card" onclick="explainPrism('gap')">
      <div class="prism-label">↔️ Diesel vs Petrol Gap</div>
      <div class="prism-value" style="color:${gapColor}">${d.gap_ppl}p</div>
      <div class="prism-sub" style="text-transform:capitalize"><strong>${d.gap_status}</strong></div>
      <div class="prism-meta">${d.gap_context}</div>
    </div>
    <div class="prism-card" onclick="explainPrism('permile')">
      <div class="prism-label">🛣️ Cost Per Mile</div>
      <div class="prism-value">${d.per_mile.petrol_medium.ppm}p</div>
      <div class="prism-sub">petrol medium (${d.per_mile.petrol_medium.mpg}mpg) · ${d.per_mile.diesel_medium.ppm}p diesel</div>
      <div class="prism-meta">SUV: ${d.per_mile.petrol_suv.ppm}p petrol / ${d.per_mile.diesel_suv.ppm}p diesel</div>
    </div>
  `;
}

// ── Drilldown Modal ─────────────────────────────────────────────
function showFpModal(html) {
  let m = document.getElementById('fpModal');
  if (!m) {
    m = document.createElement('div');
    m.id = 'fpModal';
    m.className = 'fp-modal';
    m.innerHTML = '<div class="fp-modal-backdrop" onclick="closeFpModal()"></div><div class="fp-modal-body"><button class="fp-modal-close" onclick="closeFpModal()">✕</button><div id="fpModalContent"></div></div>';
    document.body.appendChild(m);
  }
  document.getElementById('fpModalContent').innerHTML = html;
  m.classList.add('open');
}
function closeFpModal() {
  const m = document.getElementById('fpModal');
  if (m) m.classList.remove('open');
}

