// ── State ──
let stations = [];
let supplyHealth = {};
let sortField = 'e10';
let sortAsc = true;
let currentFuel = 'E10';
let map, markersLayer;
let mapInitialised = false;
let trendChart, brandChart, dayChart, historyChartInstance;
let showOpenOnly = false;
let mapFirstLoad = true;

// ── Sighting modal state ──
let sightingStationId = '';
let sightingStationNameStr = '';
let sightingHasFuel = null;
let sightingQueue = null;

// ── Accordion ──
function toggleAccordion() {
  document.getElementById('dataAccordion').classList.toggle('open');
}

// ── Tabs ──
function showTab(name, btn) {
  document.querySelectorAll('.tab-btn').forEach(t => t.classList.remove('active'));
  document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
  (btn || document.querySelector(`[data-tab="${name}"]`)).classList.add('active');
  document.getElementById('panel-' + name).classList.add('active');
  if (name === 'map') {
    setTimeout(() => { if (map) map.invalidateSize(); }, 120);
  }
}

// ── Fuel type ──
function changeFuel() {
  currentFuel = document.getElementById('fuelSelect').value;
  loadStations();
}

// ── Open now filter ──
function toggleOpenFilter() {
  showOpenOnly = !showOpenOnly;
  const btn = document.getElementById('openNowToggle');
  btn.classList.toggle('active', showOpenOnly);
  renderTable();
}

// ── Helpers ──
function fuelPrice(station, type) {
  const p = (station.prices || []).find(x => x.fuel_type === type);
  return p ? p.price : null;
}
function fuelUpdated(station, type) {
  const p = (station.prices || []).find(x => x.fuel_type === type);
  return p ? p.price_last_updated : null;
}
function formatPrice(p) { return p != null ? p.toFixed(1) + 'p' : '—'; }
function priceClass(price, prices) {
  if (price == null || !prices.length) return '';
  const sorted = prices.filter(Boolean).sort((a, b) => a - b);
  const q1 = sorted[Math.floor(sorted.length * 0.33)];
  const q2 = sorted[Math.floor(sorted.length * 0.66)];
  if (price <= q1) return 'price-cheap';
  if (price <= q2) return 'price-mid';
  return 'price-high';
}
function stationName(s) {
  const name = s.trading_name || s.name || 'Unknown';
  return name.split(' - ')[0].replace(/PETROL FILLING STATION/i, '').trim() || name;
}
function stationCity(s) {
  return (s.location || s.address || {}).city || (s.address || {}).town || '';
}
function markerColor(price, allPrices, freshness) {
  if (freshness && (freshness.status === 'stale' || freshness.status === 'closed')) return '#9ca3af';
  if (price == null || !allPrices.length) return '#9ca3af';
  const sorted = allPrices.filter(Boolean).sort((a, b) => a - b);
  const q1 = sorted[Math.floor(sorted.length * 0.33)];
  const q2 = sorted[Math.floor(sorted.length * 0.66)];
  if (price <= q1) return '#16a34a';
  if (price <= q2) return '#f59e0b';
  return '#dc2626';
}

const BRAND_COLORS = {
  TESCO:'#00539F', ASDA:'#78BE20', BP:'#009543', SHELL:'#FBCE07',
  ESSO:'#1A3668', TEXACO:'#E1261C', MORRISONS:'#007A33', SAINSBURYS:'#F06C00',
  JET:'#E30613', MURCO:'#003DA5', GULF:'#FF6600', MAXOL:'#004B87'
};
function brandBadge(brand) {
  const b = (brand || '').toUpperCase();
  const color = BRAND_COLORS[b] || '#6b7280';
  const letter = b.charAt(0) || '?';
  return `<span class="brand-badge" style="background:${color}">${letter}</span>`;
}

// ── Open status badge ──
function openBadgeHtml(s) {
  const status = s.open_status || '';
  const isOpen = s.is_open_now;
  const nc = s.next_change || {};
  if (isOpen === null || isOpen === undefined) {
    return `<span class="open-badge unknown">?</span>`;
  }
  if (!isOpen) {
    return `<span class="open-badge closed">CLOSED</span>`;
  }
  if (nc.type === 'closes' && nc.minutes <= 60) {
    return `<span class="open-badge closes-soon" title="${status}">CLOSES SOON</span>`;
  }
  if (status === 'Open 24hrs' || status === 'Open 24hrs today') {
    return `<span class="open-badge open">24HRS</span>`;
  }
  return `<span class="open-badge open">OPEN</span>`;
}

// ── Community sighting HTML ──
function sightingHtml(sighting) {
  if (!sighting) return '<span class="no-reports">No recent reports</span>';
  const queueLabels = { none: 'No queue', short: 'Short queue', long: 'Long queue' };
  const queueClass = { none: 'queue-none', short: 'queue-short', long: 'queue-long' };
  const mins = sighting.minutes_ago;
  const timeAgo = mins < 2 ? 'just now' : mins < 60 ? `${mins} min ago` : `${Math.round(mins/60)}h ago`;
  const fuelStr = sighting.has_fuel
    ? '<span class="sighting-fuel-yes">⛽ Fuel available</span>'
    : '<span class="sighting-fuel-no">❌ No fuel</span>';
  const queueStr = `<span class="queue-pill ${queueClass[sighting.queue_length] || ''}">${queueLabels[sighting.queue_length] || sighting.queue_length}</span>`;
  const noteStr = sighting.note ? `<span style="color:var(--w-text-muted);font-size:11px"> — ${sighting.note}</span>` : '';
  return `<div class="sighting-item">
    <span class="sighting-time">${timeAgo}</span>
    <span>${fuelStr} ${queueStr}${noteStr}</span>
  </div>`;
}

function communityBadgeHtml(s) {
  const sighting = s.latest_sighting;
  const stationId = s.node_id || '';
  const name = stationName(s).replace(/'/g, "\\'");
  if (sighting) {
    const mins = sighting.minutes_ago;
    const timeAgo = mins < 2 ? 'now' : mins < 60 ? `${mins}m` : `${Math.round(mins/60)}h`;
    const fuelIcon = sighting.has_fuel ? '⛽' : '❌';
    const queueIcons = { none: '', short: '🛒', long: '🛒🛒' };
    return `<span style="font-size:11px;color:var(--w-text-muted)" title="${sighting.has_fuel ? 'Fuel available' : 'No fuel'} ${sighting.queue_length} queue - ${timeAgo} ago">${fuelIcon} ${timeAgo}</span>`;
  }
  return '';
}

// ── Supply Banner ──
function updateSupplyBanner(health) {
  const banner = document.getElementById('supplyBanner');
  const label = document.getElementById('supplyLabel');
  const detail = document.getElementById('supplyDetail');
  const stats = document.getElementById('supplyStats');
  const freshPct = health.fresh_pct || 0;
  const totalOpen = health.total_open ?? health.total;

  let status = health.status || 'normal';
  if (status === 'alert' && freshPct > 50) status = 'watch';

  banner.className = 'supply-badge ' + status;
  const statusLabel = { normal: 'Supply Normal', watch: 'Supply Watch', alert: 'Supply Alert' }[status] || 'Supply Normal';
  const emoji = { normal: '✓', watch: '⚠', alert: '!' }[status] || '✓';
  label.textContent = `${emoji} ${statusLabel}`;
  detail.textContent = `${freshPct}% fresh · ${totalOpen} open now`;
  stats.innerHTML = `
    <span class="supply-stat">🟢 ${health.fresh || 0}</span>
    <span class="supply-stat">🟡 ${health.aging || 0}</span>
    <span class="supply-stat">🔴 ${health.stale || 0}</span>
    <span class="supply-stat">⚫ ${health.closed || 0}</span>
  `;
}

// ── Map ──
function initMap() {
  if (mapInitialised) return;
  mapInitialised = true;
  try {
    map = L.map('map', { zoomControl: true }).setView([55.46, -4.63], 11);
    const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
    mapTileLayer = L.tileLayer(isDark
      ? 'https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png'
      : 'https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png', {
      attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors &copy; <a href="https://carto.com/attributions">CARTO</a>',
      subdomains: 'abcd',
      maxZoom: 19
    }).addTo(map);
    markersLayer = L.layerGroup().addTo(map);
  } catch (err) {
    console.error('Map init failed:', err);
    mapInitialised = false;
  }
}

function updateMap() {
  if (!map) return;
  markersLayer.clearLayers();
  const allPrices = stations.map(s => fuelPrice(s, currentFuel)).filter(p => p != null);

  stations.forEach(s => {
    const lat = s.lat || (s.location || {}).latitude;
    const lon = s.lon || (s.location || {}).longitude;
    if (!lat || !lon) return;

    const price = fuelPrice(s, currentFuel);
    const freshness = s.freshness || {};
    const color = markerColor(price, allPrices, freshness);
    const name = stationName(s);
    const brand = s.brand_name || s.brand || '';
    const city = stationCity(s);
    const dist = s.distance != null ? s.distance.toFixed(1) + ' mi' : '';

    let pricesHtml = '';
    (s.prices || []).forEach(p => {
      const fuelLabels = { E10: 'Unleaded (E10)', B7_STANDARD: 'Diesel', E5: 'Super (E5)' };
      const label = fuelLabels[p.fuel_type] || p.fuel_type;
      pricesHtml += `<tr><td style="padding:3px 10px 3px 0;color:#6b7280;font-size:12px">${label}</td><td style="font-weight:700;font-size:13px">${p.price ? p.price.toFixed(1) + 'p' : '—'}</td></tr>`;
    });

    const openStatus = s.open_status || '';
    const openBadge = openBadgeHtml(s);
    const sighting = s.latest_sighting;
    const sightingLine = sighting
      ? `${sighting.has_fuel ? '⛽ Fuel reported' : '❌ No fuel reported'} · ${sighting.minutes_ago < 60 ? sighting.minutes_ago + ' min ago' : Math.round(sighting.minutes_ago/60) + 'h ago'}`
      : 'No community reports';
    const stationIdSafe = (s.node_id || '').replace(/'/g, "\\'");
    const nameSafe = name.replace(/'/g, "\\'");

    const traffic = s.traffic || {};
    const trafficBadge = traffic.status && traffic.status !== 'clear'
      ? `<div class="traffic-badge traffic-${traffic.status}">🚦 ${traffic.detail}</div>`
      : '<div class="traffic-badge traffic-clear">🟢 Clear roads</div>';

    const popup = `
      <div style="min-width:200px;font-family:Inter,sans-serif">
        <div style="font-weight:700;font-size:14px;margin-bottom:2px">${name}</div>
        <div style="font-size:12px;color:#6b7280;margin-bottom:6px">${[brand, city, dist].filter(Boolean).join(' · ')}</div>
        <div style="margin-bottom:8px">${openBadge} <span style="font-size:11px;color:#6b7280;margin-left:4px">${openStatus}</span></div>
        <div style="margin-bottom:6px">${trafficBadge}</div>
        <table style="width:100%;border-collapse:collapse">${pricesHtml}</table>
        <div style="font-size:11px;color:#9ca3af;margin-top:6px;padding-top:6px;border-top:1px solid #f3f4f6">${freshness.icon || ''} ${freshness.label || ''} ${freshness.detail ? '— ' + freshness.detail : ''}</div>
        <div style="margin-top:8px;padding-top:8px;border-top:1px solid #f3f4f6">
          <div style="font-size:11px;font-weight:600;color:#6b7280;margin-bottom:4px">👥 Community</div>
          <div style="font-size:11px;color:#374151">${sightingLine}</div>
          <button onclick="openSightingModal('${stationIdSafe}','${nameSafe}')" style="margin-top:6px;padding:4px 10px;border:1px solid #e5e7eb;border-radius:6px;background:none;font-size:11px;cursor:pointer;font-family:inherit">📍 I'm here — Report</button>
        </div>
      </div>`;

    const isSelected = price != null && price === Math.min(...allPrices);
    const marker = L.circleMarker([lat, lon], {
      radius: isSelected ? 12 : 9,
      fillColor: color,
      color: isSelected ? '#1a1a2e' : 'rgba(255,255,255,0.8)',
      weight: isSelected ? 2.5 : 1.5,
      fillOpacity: 0.88
    }).bindPopup(popup, { maxWidth: 260 });
    markersLayer.addLayer(marker);

    // Traffic ring indicator for congested stations
    if (s.traffic && s.traffic.score > 0.5) {
      const trafficRing = L.circleMarker([lat, lon], {
        radius: (isSelected ? 12 : 9) + 4,
        fillColor: 'transparent',
        color: s.traffic.score > 0.7 ? '#ef4444' : '#f59e0b',
        weight: 2,
        fillOpacity: 0,
        opacity: 0.6,
        dashArray: '4,4'
      });
      markersLayer.addLayer(trafficRing);
    }
  });

  if (mapFirstLoad) {
    const validCoords = stations
      .filter(s => (s.lat || (s.location || {}).latitude) && (s.lon || (s.location || {}).longitude))
      .map(s => [s.lat || s.location.latitude, s.lon || s.location.longitude]);
    if (validCoords.length > 0) {
      try { map.fitBounds(validCoords, { padding: [32, 32], maxZoom: 13 }); } catch(e) {}
    }
    mapFirstLoad = false;
  }
}

