async function submitSighting() {
  const errEl = document.getElementById('sightingError');
  errEl.style.display = 'none';

  if (sightingHasFuel === null) {
    errEl.textContent = 'Please select whether fuel is available.';
    errEl.style.display = 'block';
    return;
  }
  if (!sightingQueue) {
    errEl.textContent = 'Please select a queue length.';
    errEl.style.display = 'block';
    return;
  }

  const btn = document.getElementById('submitSightingBtn');
  btn.disabled = true;
  btn.textContent = 'Submitting…';

  try {
    const res = await fetch('/api/sighting', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        station_id: sightingStationId,
        has_fuel: sightingHasFuel,
        queue_length: sightingQueue,
        note: document.getElementById('sightingNote').value.trim() || null,
      })
    });
    if (res.status === 429) {
      errEl.textContent = 'You reported this station recently. Please wait 15 minutes.';
      errEl.style.display = 'block';
      btn.disabled = false;
      btn.textContent = 'Submit Report';
      return;
    }
    if (!res.ok) {
      const d = await res.json();
      throw new Error(d.detail || 'Server error');
    }
    document.getElementById('sightingFormWrap').style.display = 'none';
    document.getElementById('sightingSuccess').style.display = 'block';
    setTimeout(() => loadStations(), 800);
    setTimeout(() => closeSightingModal(), 3000);
  } catch (e) {
    errEl.textContent = e.message || 'Failed to submit. Please try again.';
    errEl.style.display = 'block';
    btn.disabled = false;
    btn.textContent = 'Submit Report';
  }
}

// ── Data Loading ──
async function loadStations() {
  try {
    const data = await fetch(`/api/stations?fuel=${currentFuel}&radius=20`).then(r => r.json());
    stations = data.stations || [];
    supplyHealth = data.supply_health || {};

    updateSupplyBanner(supplyHealth);
    document.getElementById('stationCount').textContent = stations.length;

    let cheapE10 = { price: 9999, name: '' }, cheapDiesel = { price: 9999, name: '' };
    let e10Prices = [], dieselPrices = [];

    stations.forEach(s => {
      const name = stationName(s);
      const brand = s.brand_name || s.brand || '';
      const isFresh = (s.freshness || {}).status === 'fresh';
      (s.prices || []).forEach(p => {
        if (p.fuel_type === 'E10' && p.price != null) {
          e10Prices.push(p.price);
          if (isFresh && p.price < cheapE10.price) cheapE10 = { price: p.price, name: `${brand} ${stationCity(s)}`.trim() || name };
        }
        if (p.fuel_type === 'B7_STANDARD' && p.price != null) {
          dieselPrices.push(p.price);
          if (isFresh && p.price < cheapDiesel.price) cheapDiesel = { price: p.price, name: `${brand} ${stationCity(s)}`.trim() || name };
        }
      });
    });

    document.getElementById('cheapE10').textContent = cheapE10.price < 9999 ? cheapE10.price.toFixed(1) + 'p' : '—';
    document.getElementById('cheapE10Station').textContent = cheapE10.name || '—';
    document.getElementById('cheapDiesel').textContent = cheapDiesel.price < 9999 ? cheapDiesel.price.toFixed(1) + 'p' : '—';
    document.getElementById('cheapDieselStation').textContent = cheapDiesel.name || '—';

    const avgE10 = e10Prices.length ? (e10Prices.reduce((a, b) => a + b, 0) / e10Prices.length) : null;
    document.getElementById('avgE10').textContent = avgE10 != null ? avgE10.toFixed(1) + 'p' : '—';

    if (e10Prices.length >= 2) {
      const maxE10 = Math.max(...e10Prices);
      const minE10 = Math.min(...e10Prices);
      const diff = maxE10 - minE10;
      const tankSaving = (diff / 100 * 55).toFixed(2);
      const annualSaving = (tankSaving * 52).toFixed(0);
      document.getElementById('avgE10Detail').textContent = `Range: ${minE10.toFixed(1)}p – ${maxE10.toFixed(1)}p (${diff.toFixed(1)}p spread)`;
      document.getElementById('tipSavings').textContent = `£${tankSaving}`;
      document.getElementById('tipSavingsDetail').textContent = `Save £${tankSaving} per 55L tank — that's ${diff.toFixed(1)}p/L between cheapest and priciest`;
      document.getElementById('tipAnnual').textContent = `£${annualSaving}/yr`;
    }

    // Traffic impact summary
    const stationsInTraffic = stations.filter(s => s.traffic && s.traffic.score > 0.3).length;
    document.getElementById('trafficImpact').textContent = stationsInTraffic > 0 ? stationsInTraffic + ' stations' : 'All Clear';
    document.getElementById('trafficImpact').className = 'stat-value' + (stationsInTraffic > 3 ? ' red' : stationsInTraffic > 0 ? ' amber' : ' green');
    document.getElementById('trafficImpactDetail').textContent = stationsInTraffic > 0
      ? stationsInTraffic + ' station' + (stationsInTraffic > 1 ? 's' : '') + ' near congestion'
      : 'No congestion near any station';

    updateMap();
    renderTable();
  } catch (e) {
    console.error('Station load failed:', e);
  }
}

async function loadTrends() {
  try {
    const [e10Trends, dieselTrends] = await Promise.all([
      fetch('/api/trends?fuel=E10&days=90').then(r => r.json()),
      fetch('/api/trends?fuel=B7_STANDARD&days=90').then(r => r.json())
    ]);

    const analysis = e10Trends.analysis || {};
    const trendEl = document.getElementById('trendValue');
    const arrow = analysis.direction === 'rising' ? '\u2191' : analysis.direction === 'falling' ? '\u2193' : '\u2192';
    const label = (analysis.direction || 'Stable').charAt(0).toUpperCase() + (analysis.direction || 'stable').slice(1);
    const rate = analysis.change_7d != null ? ` (${analysis.change_7d > 0 ? '+' : ''}${analysis.change_7d.toFixed(1)}p/wk)` : '';
    trendEl.textContent = `${arrow} ${label}${rate}`;
    trendEl.className = 'stat-value' + (analysis.direction === 'rising' ? ' red' : analysis.direction === 'falling' ? ' green' : '');
