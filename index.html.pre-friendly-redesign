function flyToStation(lat, lon) {
  showTab('map', document.querySelector('[data-tab="map"]'));
  setTimeout(() => {
    if (!map) return;
    map.invalidateSize();
    map.flyTo([lat, lon], 15, { duration: 0.8 });
    markersLayer.eachLayer(layer => {
      try {
        const ll = layer.getLatLng();
        if (Math.abs(ll.lat - lat) < 0.001 && Math.abs(ll.lng - lon) < 0.001) {
          layer.openPopup();
        }
      } catch(e) {}
    });
  }, 200);
}

// ── Table ──
function renderTable() {
  const tbody = document.getElementById('stationTableBody');
  const allE10 = stations.map(s => fuelPrice(s, 'E10')).filter(p => p != null);
  const allDiesel = stations.map(s => fuelPrice(s, 'B7_STANDARD')).filter(p => p != null);
  const allE5 = stations.map(s => fuelPrice(s, 'E5')).filter(p => p != null);
  const cheapE10 = allE10.length ? Math.min(...allE10) : null;
  const cheapDiesel = allDiesel.length ? Math.min(...allDiesel) : null;

  let filtered = showOpenOnly ? stations.filter(s => s.is_open_now === true) : stations;

  const openCount = stations.filter(s => s.is_open_now === true).length;
  document.getElementById('filterCount').textContent = showOpenOnly
    ? `Showing ${filtered.length} open stations`
    : `${openCount} of ${stations.length} open now`;

  const statusOrder = { fresh: 0, aging: 1, stale: 2, closed: 3 };
  const sorted = [...filtered].sort((a, b) => {
    const fa = a.freshness || {}, fb = b.freshness || {};
    const sa = statusOrder[fa.status] ?? 2, sb = statusOrder[fb.status] ?? 2;
    if (sortField === 'hours') {
      const oa = a.is_open_now === true ? 0 : a.is_open_now === false ? 1 : 2;
      const ob = b.is_open_now === true ? 0 : b.is_open_now === false ? 1 : 2;
      return sortAsc ? oa - ob : ob - oa;
    }
    if (sortField === 'status' && sa !== sb) return sortAsc ? sa - sb : sb - sa;
    let va, vb;
    switch (sortField) {
      case 'name': return sortAsc ? stationName(a).localeCompare(stationName(b)) : stationName(b).localeCompare(stationName(a));
      case 'brand': return sortAsc ? (a.brand||'').localeCompare(b.brand||'') : (b.brand||'').localeCompare(a.brand||'');
      case 'distance': va = a.distance || 99; vb = b.distance || 99; break;
      case 'e10': va = fuelPrice(a, 'E10') || 999; vb = fuelPrice(b, 'E10') || 999; break;
      case 'diesel': va = fuelPrice(a, 'B7_STANDARD') || 999; vb = fuelPrice(b, 'B7_STANDARD') || 999; break;
      case 'e5': va = fuelPrice(a, 'E5') || 999; vb = fuelPrice(b, 'E5') || 999; break;
      case 'updated':
        va = fuelUpdated(a, currentFuel) || '';
        vb = fuelUpdated(b, currentFuel) || '';
        return sortAsc ? vb.localeCompare(va) : va.localeCompare(vb);
      case 'status': va = sa; vb = sb; break;
      default: va = fuelPrice(a, currentFuel) || 999; vb = fuelPrice(b, currentFuel) || 999;
    }
    return sortAsc ? va - vb : vb - va;
  });

  tbody.innerHTML = sorted.map(s => {
    const e10 = fuelPrice(s, 'E10');
    const diesel = fuelPrice(s, 'B7_STANDARD');
    const e5 = fuelPrice(s, 'E5');
    const f = s.freshness || {};
    const brand = s.brand_name || s.brand || '';
    const lat = s.lat || (s.location || {}).latitude;
    const lon = s.lon || (s.location || {}).longitude;
    const dist = s.distance != null ? s.distance.toFixed(1) + ' mi' : '—';
    const name = stationName(s);
    const city = stationCity(s);
    const isCheapest = ((e10 != null && e10 === cheapE10) || (diesel != null && diesel === cheapDiesel)) && (f.status === 'fresh');

    let rowClass = '';
    if (f.status === 'closed') rowClass = 'closed-row';
    else if (f.status === 'stale') rowClass = 'stale-row';
    else if (isCheapest) rowClass = 'cheapest';
    const freshnessClass = { fresh:'freshness-fresh', aging:'freshness-aging', stale:'freshness-stale', closed:'freshness-closed' }[f.status] || '';
    const cheapestBadge = isCheapest ? '<span class="cheapest-badge">★ CHEAPEST</span>' : '';

    const openBadge = openBadgeHtml(s);
    const openStatusText = s.open_status || '';
    const stationIdSafe = (s.node_id || '').replace(/'/g, "\\'");
    const nameSafe = name.replace(/'/g, "\\'");

    return `<tr class="${rowClass}">
      <td><span class="freshness-badge ${freshnessClass}">${f.icon || ''} ${f.label || ''}</span></td>
      <td>
        <div>${openBadge}</div>
        <div style="font-size:10px;color:var(--w-text-muted);margin-top:2px;white-space:nowrap;max-width:100px;overflow:hidden;text-overflow:ellipsis" title="${openStatusText}">${openStatusText}</div>
      </td>
      <td>
        <strong>${name}</strong>${cheapestBadge}
        ${city ? `<br><span style="font-size:11px;color:var(--w-text-muted)">${city}</span>` : ''}
      </td>
      <td>${brandBadge(brand)}<span style="font-size:13px">${brand}</span></td>
      <td style="color:var(--w-text-muted);font-size:13px">${dist}</td>
      <td class="price-cell ${priceClass(e10, allE10)}">${formatPrice(e10)}</td>
      <td class="price-cell ${priceClass(diesel, allDiesel)}">${formatPrice(diesel)}</td>
      <td class="price-cell ${priceClass(e5, allE5)}">${formatPrice(e5)}</td>
      <td style="font-size:12px;color:var(--w-text-muted)">${f.hours_since_update != null ? (f.hours_since_update < 1 ? '<1h' : Math.round(f.hours_since_update) + 'h') + ' ago' : '—'}</td>
      <td><span class="traffic-badge traffic-${(s.traffic||{}).status||'clear'}">${{heavy:'🔴',moderate:'🟡',light:'🟢',clear:'🟢'}[(s.traffic||{}).status||'clear']} ${((s.traffic||{}).status||'clear').charAt(0).toUpperCase()+((s.traffic||{}).status||'clear').slice(1)}</span></td>
      <td>${communityBadgeHtml(s)}</td>
      <td>
        ${lat ? `<button class="btn-sm" onclick="flyToStation(${lat},${lon})" title="Show on map">📍</button>` : ''}
        <button class="btn-sm" onclick="showHistory('${s.node_id}','${nameSafe}')">📈</button>
        <button class="btn-sm report-btn" onclick="openSightingModal('${stationIdSafe}','${nameSafe}');event.stopPropagation()" title="Report">📍</button>
      </td>
    </tr>`;
  }).join('');
}

function sortTable(field) {
  if (sortField === field) sortAsc = !sortAsc;
  else { sortField = field; sortAsc = true; }
  renderTable();
}

