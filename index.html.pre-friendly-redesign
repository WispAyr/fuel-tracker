    document.getElementById('tipTrend').textContent = analysis.description || '\u2014';
    document.getElementById('tipTrendDetail').textContent = `7-day change: ${(analysis.change_7d || 0) > 0 ? '+' : ''}${(analysis.change_7d || 0).toFixed(1)}p/litre`;

    const e10Points = (e10Trends.trends || []).map(t => ({ x: t.date, y: t.avgPricePence }));
    const dieselPoints = (dieselTrends.trends || []).map(t => ({ x: t.date, y: t.avgPricePence }));

